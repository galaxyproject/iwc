{
    "a_galaxy_workflow": "true",
    "annotation": "Runs HyPhy BUSTED, FEL, MEME and PRIME analyses on a collection of fasta.",
    "comments": [],
    "creator": [
        {
            "class": "Person",
            "name": "Danielle Callan"
        },
