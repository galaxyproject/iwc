{
    "a_galaxy_workflow": "true",
    "annotation": "Given a reference assembly, search NCBI for related-species genomes using RefSeq Masher, apply user-defined taxonomic and assembly-quality filters (assembly level, type, BioSample sex, sequencing technology, taxonomic class, number of chromosomes), and download the genome fastas of the n closest matching related species. Useful for assembling a synteny reference set ahead of manual curation workflows such as JBrowse2 precuration tracks.",
    "comments": [],
    "creator": [
        {
            "class": "Person",
            "identifier": "https://orcid.org/0000-0001-6421-3484",
            "name": "Delphine Lariviere"
        },
        {
            "class": "Organization",
            "name": "IWC"
        }
    ],
    "format-version": "0.1",
    "license": "MIT",
    "name": "Fetch Related Genomes",
    "report": {
