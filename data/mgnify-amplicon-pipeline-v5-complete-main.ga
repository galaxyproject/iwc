                        "tool_state": "{\"code\": \"NR > 2 { \\n        split($3, taxa, \\\";\\\");\\n        merged = \\\"\\\";\\n        levels = 3; # We need sk__, k__, and p__ levels\\n        for (i = 1; i <= levels; i++) {\\n            if (i <= length(taxa) && taxa[i] ~ /__/) {\\n                split(taxa[i], parts, \\\"__\\\");\\n                if (parts[2] != \\\"\\\") {\\n                    value = parts[2];\\n                } else {\\n                    value = \\\"unassigned\\\";\\n                }\\n            } else {\\n                value = \\\"unassigned\\\";\\n            }\\n            merged = merged (merged ? \\\";\\\" : \\\"\\\") value;\\n        }\\n        print merged \\\"\\\\t\\\" $2;\\n    }\", \"infile\": {\"__class__\": \"ConnectedValue\"}, \"variables\": [], \"__page__\": null, \"__rerun_remap_job_id__\": null}",
