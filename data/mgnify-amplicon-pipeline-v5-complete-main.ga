                        "tool_state": "{\"code\": \"BEGIN {\\n  FS=OFS=\\\"\\\\t\\\"\\n}\\nNR == 1 {\\n  # Print the renamed headers for the new columns\\n  printf \\\"superkingdom\\\\tkingdom\\\\tphylum\\\"\\n  # Adjust the remaining original headers to only include the part before the first underscore\\n  for (i = 2; i <= NF; i++) {\\n    split($i, header_parts, \\\"_\\\")\\n    printf \\\"\\\\t%s\\\", header_parts[1]\\n  }\\n  printf \\\"\\\\n\\\"\\n}\\nNR > 1 {\\n  # Split the first column by ';' into three parts\\n  split($1, taxa_parts, \\\";\\\")\\n  superkingdom = (taxa_parts[1] != \\\"\\\" ? taxa_parts[1] : \\\"unassigned\\\")\\n  kingdom = (length(taxa_parts[2]) ? taxa_parts[2] : \\\"unassigned\\\")\\n  phylum = (length(taxa_parts[3]) ? taxa_parts[3] : \\\"unassigned\\\")\\n  printf \\\"%s\\\\t%s\\\\t%s\\\", superkingdom, kingdom, phylum\\n  # Process the remaining columns\\n  for (i = 2; i <= NF; i++) {\\n    if ($i != \\\"\\\") {\\n      split($i, part, \\\"_\\\")\\n      printf \\\"\\\\t%s\\\", part[1]\\n    } else {\\n      printf \\\"\\\\tunassigned\\\"\\n    }\\n  }\\n  printf \\\"\\\\n\\\"\\n}\", \"infile\": {\"__class__\": \"ConnectedValue\"}, \"variables\": [], \"__page__\": null, \"__rerun_remap_job_id__\": null}",
