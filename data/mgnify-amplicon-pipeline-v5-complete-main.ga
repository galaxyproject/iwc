                        "tool_state": "{\"code\": \"BEGIN {\\n  FS=OFS=\\\"\\\\t\\\"\\n}\\nNR == 1 {\\n  # Print the first header as it is\\n  printf \\\"%s\\\", $1\\n  # Adjust the remaining original headers to only include the part before the first underscore\\n  for (i = 2; i <= NF; i++) {\\n    split($i, header_parts, \\\"_\\\")\\n    printf \\\"\\\\t%s\\\", header_parts[1]\\n  }\\n  printf \\\"\\\\n\\\"\\n}\\nNR > 1 {\\n  # Print the rest of the lines as they are\\n  for (i = 1; i <= NF; i++) {\\n    printf \\\"%s%s\\\", $i, (i < NF ? OFS : ORS)\\n  }\\n}\", \"infile\": {\"__class__\": \"ConnectedValue\"}, \"variables\": [], \"__page__\": null, \"__rerun_remap_job_id__\": null}",
